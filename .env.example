# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored — never commit it.

# Neon Postgres connection string.
# Sign up at https://neon.tech (free), create a project, then copy the pooled
# connection string from the dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# A second non-pooled URL for migrations (Prisma needs a direct connection).
# Neon shows this as the "Direct" connection string in the same dashboard.
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Secret for signing cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=replace_with_generated_hex_string

# Invite code required to create a new calendar.
# Anyone who knows this code can create a calendar.
INVITE_CODE=replace_with_your_invite_code
